---
// HeroDivider — Dual Rail between Hero and Experience.
//
// Visual: amber hairline (top rail) + blue hairline (bottom rail), 5px apart,
// both extending symmetrically from centre outward. Width is content-column
// width (max-width + gutters), matching StackDivider / ProjectsDivider — NOT
// full-bleed like the old amber Horizon.
//
// Scroll behaviour:
//   - CSS transitions handle bidirectional in/out as the element enters/leaves
//     the viewport (same pattern as StackDivider). The global IntersectionObserver
//     in index.astro drives this via [data-rule-reveal].
//   - GSAP shimmer scan runs ONCE on first appearance and never again.
//     A MutationObserver watches for the first 'is-visible' class addition,
//     fires the shimmer, then disconnects.
//   - Shimmer uses actual container pixel width (getBoundingClientRect) so
//     it travels the full scan-wrap and isn't clipped prematurely.
---

<div class="hero-divider" data-rule-reveal data-hero-divider aria-hidden="true">
  <div class="hd-inner">
    <span class="hd-rail hd-amber"></span>
    <div class="hd-scan-wrap" aria-hidden="true">
      <div class="hd-scan"></div>
    </div>
    <span class="hd-rail hd-blue"></span>
  </div>
</div>

<style>
  /* ─── Outer wrapper — no full-bleed, sits inside normal flow ── */
  .hero-divider {
    padding-block: var(--space-3);
    pointer-events: none;
  }

  /* ─── Inner row — matches content column width ──────────────── */
  .hd-inner {
    position: relative;
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--gutter);
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  /* ─── Rails — CSS transition, scaleX from centre ────────────── */
  /* Bidirectional: fades in when is-visible is added, reverses     */
  /* when removed. Global IO debounce prevents flicker on thin      */
  /* elements. Spring easing matches StackDivider / ProjectsDivider. */
  .hd-rail {
    display: block;
    height: 1px;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 880ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hd-amber {
    background: linear-gradient(
      90deg,
      rgba(245, 158, 11, 0)    0%,
      rgba(245, 158, 11, 0.65) 12%,
      rgba(245, 158, 11, 0.55) 50%,
      rgba(245, 158, 11, 0.65) 88%,
      rgba(245, 158, 11, 0)   100%
    );
    /* Amber leads — no extra delay */
  }

  .hd-blue {
    background: linear-gradient(
      90deg,
      rgba(59, 130, 246, 0)    0%,
      rgba(59, 130, 246, 0.48) 12%,
      rgba(59, 130, 246, 0.38) 50%,
      rgba(59, 130, 246, 0.48) 88%,
      rgba(59, 130, 246, 0)   100%
    );
    /* Blue follows amber by 180 ms */
    transition-delay: 180ms;
  }

  .hero-divider.is-visible .hd-rail {
    transform: scaleX(1);
  }

  /* ─── Scan clip container ───────────────────────────────────── */
  /* overflow:hidden clips the shimmer element to the content       */
  /* column. Inset by gutter to match the rail end-stops exactly.   */
  .hd-scan-wrap {
    position: absolute;
    left: var(--gutter);
    right: var(--gutter);
    top: 0;
    bottom: 0;
    overflow: hidden;
    pointer-events: none;
  }

  /* ─── Shimmer element ───────────────────────────────────────── */
  /* A 70 px flash that sweeps left→right across the scan-wrap.    */
  /* Triggered ONCE by the .do-shimmer class (JS adds it on first   */
  /* is-visible, never removes it). The @keyframes animates `left`  */
  /* so "100%" correctly resolves to the scan-wrap's own width —    */
  /* no JavaScript pixel measurement needed.                         */
  .hd-scan {
    position: absolute;
    top: 0;
    bottom: 0;
    left: -100px;            /* starts fully off-screen left */
    width: 70px;
    background: linear-gradient(
      90deg,
      transparent                    0%,
      rgba(255, 255, 255, 0.12)     28%,
      rgba(255, 255, 255, 0.82)     50%,
      rgba(255, 255, 255, 0.12)     72%,
      transparent                   100%
    );
    filter: blur(0.4px);
    border-radius: 2px;
    opacity: 0;
    pointer-events: none;
  }

  /* One-shot: class is added exactly once, animation plays once.   */
  .hero-divider.do-shimmer .hd-scan {
    animation: hd-scan-run 820ms linear forwards;
    animation-delay: 490ms;  /* rails are ~55% extended when shimmer starts */
  }

  @keyframes hd-scan-run {
    0%   { left: -100px; opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { left: calc(100% + 100px); opacity: 0; }
  }

  /* ─── Mobile ─────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .hd-inner { gap: 4px; }
  }

  /* ─── Reduced motion ─────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hd-rail {
      transition-duration: 1ms !important;
      transition-delay:    0ms !important;
    }
    .hd-scan { display: none; }
  }
</style>

<script>
  // Watch for the global IO in index.astro adding 'is-visible'.
  // On first addition, fire the shimmer once and disconnect.
  const divider = document.querySelector<HTMLElement>('[data-hero-divider]');

  if (divider) {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReduced) {
      let shimmerFired = false;

      const obs = new MutationObserver(() => {
        if (!shimmerFired && divider.classList.contains('is-visible')) {
          shimmerFired = true;
          divider.classList.add('do-shimmer');
          obs.disconnect();
        }
      });

      obs.observe(divider, { attributes: true, attributeFilter: ['class'] });
    }
  }
</script>
