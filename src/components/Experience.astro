---
// Experience — Section 01
// Two-track split: Work (left) | Study (right).
// Reads faster than a unified timeline — paths compared at a glance.
// Ref: DESIGN_SPEC.md §4, §5, §6, §7.

type Entry = {
  period: string;
  role: string;
  company: string;
  location?: string;
  description?: string;
  current?: boolean;
  kind: 'work' | 'study';
};

const entries: Entry[] = [
  {
    period: '02/2026 — 09/2026',
    role: 'IT Trainee',
    company: 'Harvia',
    location: 'Muurame, FI',
    description:
      'IT administration at a publicly listed manufacturer — Intune fleet management, ERP support across production operations, service desk coverage, and contributions to company-wide IT projects.',
    current: true,
    kind: 'work',
  },
  {
    period: '09/2024 →',
    role: 'Road Closing',
    company: 'Toyota Gazoo Racing',
    description:
      'Part of the test-stage crew for Toyota Gazoo Racing — closing and securing special stages before driver runs. Safety-critical work in pre-event preparation.',
    current: true,
    kind: 'work',
  },
  {
    period: '08/2023 →',
    role: 'B.Eng. Information Technology',
    company: 'JAMK University of Applied Sciences',
    location: 'Jyväskylä, FI',
    description:
      'Advanced programming track with a specialisation in AI and data analytics — CRISP-DM pipelines, large-scale ML, DevOps. Expected graduation 05/2027.',
    current: true,
    kind: 'study',
  },
  {
    period: '08/2016 — 05/2019',
    role: 'Vocational ICT',
    company: 'Sedu, Lapua',
    location: 'Lapua, FI',
    description:
      'Vocational qualification in Information and Communications Technology.',
    kind: 'study',
  },
];

const work  = entries.filter((e) => e.kind === 'work');
const study = entries.filter((e) => e.kind === 'study');
const workHasCurrent  = work.some((e) => e.current);
const studyHasCurrent = study.some((e) => e.current);
const rows = Math.max(work.length, study.length);
---

<section class="exp" id="experience" aria-labelledby="exp-heading">
  <div class="container exp-wrap">

    <header class="exp-header">
      <p class="section-index mono" data-reveal>01 · Experience</p>
      <h2 class="exp-heading" id="exp-heading" data-reveal data-reveal-delay="1">
        Experience across<br />
        <span class="exp-accent">data, systems</span> and
        <span class="exp-accent">performance</span>.
      </h2>
      <p class="exp-lede" data-reveal data-reveal-delay="2">
        Work and study across IT operations, software engineering and AI —
        and a recurring test-stage role with Toyota Gazoo Racing.
      </p>
    </header>

    <!-- Two-track grid. Headers occupy row 1, then each row slot
         (row 2..N+1) is shared across both columns so work[i] and
         study[i] size to the same height — Road Closing lines up
         with Vocational ICT regardless of description length. -->
    <div class="exp-tracks" data-reveal data-reveal-exp data-reveal-delay="3" data-stacked={rows}>

      <header class="track-head" data-track="work" data-col="1">
        <span class="mono track-glyph">◆ Work</span>
        {workHasCurrent && <span class="track-pulse" aria-hidden="true"></span>}
        <span class="mono track-count">{work.length} {work.length === 1 ? 'entry' : 'entries'}</span>
      </header>

      <header class="track-head" data-track="study" data-col="2">
        <span class="mono track-glyph track-glyph-study">◇ Study</span>
        {studyHasCurrent && <span class="track-pulse" aria-hidden="true"></span>}
        <span class="mono track-count">{study.length} {study.length === 1 ? 'entry' : 'entries'}</span>
      </header>

      {work.map((e, i) => (
        <article class="entry" data-current={e.current ? 'true' : 'false'} data-col="1" data-row={i + 2}>
          <div class="entry-meta">
            <span class="mono entry-period">{e.period}</span>
            {e.current && (
              <span class="entry-current">
                <span class="entry-pulse" aria-hidden="true"></span>
                <span class="mono entry-current-label">Current</span>
              </span>
            )}
          </div>
          <h3 class="entry-role">{e.role}</h3>
          <p class="entry-company">
            <span class="entry-company-name">{e.company}</span>
            {e.location && <span class="entry-divider" aria-hidden="true">·</span>}
            {e.location && <span class="entry-location mono">{e.location}</span>}
          </p>
          {e.description && <p class="entry-desc">{e.description}</p>}
        </article>
      ))}

      {study.map((e, i) => (
        <article class="entry" data-current={e.current ? 'true' : 'false'} data-col="2" data-row={i + 2}>
          <div class="entry-meta">
            <span class="mono entry-period">{e.period}</span>
            {e.current && (
              <span class="entry-current">
                <span class="entry-pulse" aria-hidden="true"></span>
                <span class="mono entry-current-label">Current</span>
              </span>
            )}
          </div>
          <h3 class="entry-role">{e.role}</h3>
          <p class="entry-company">
            <span class="entry-company-name">{e.company}</span>
            {e.location && <span class="entry-divider" aria-hidden="true">·</span>}
            {e.location && <span class="entry-location mono">{e.location}</span>}
          </p>
          {e.description && <p class="entry-desc">{e.description}</p>}
        </article>
      ))}

    </div>

  </div>
</section>

<style>
  /* ─── Layout ──────────────────────────────────────────────── */
  .exp {
    padding-block: var(--space-13) var(--space-13);
    position: relative;
  }

  .exp-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-8);
  }

  /* ─── Header ──────────────────────────────────────────────── */
  .exp-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-8);
    align-items: end;
    margin-bottom: var(--space-3);
  }

  .exp-header .section-index {
    grid-column: 1 / -1;
    margin-bottom: var(--space-3);
  }

  .exp-heading {
    grid-column: 1 / 2;
    font-size: var(--text-display-l);
    color: var(--text);
    line-height: 1.02;
  }

  .exp-accent {
    color: var(--primary-soft);
    font-style: italic;
    font-weight: 300;
  }

  .exp-lede {
    grid-column: 2 / 3;
    color: var(--text-muted);
    font-size: var(--text-body-l);
    line-height: 1.55;
    max-width: 46ch;
    justify-self: end;
    padding-bottom: 6px;
  }

  /* ─── Two-track grid with shared rows ─────────────────────── */
  /* Headers in row 1, entries in rows 2..N+1. Each row sizes to
     its tallest cell, so work[i] and study[i] always share a
     baseline. No subgrid needed — explicit grid-row placement
     does the job and is well-supported. */
  .exp-tracks {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: var(--space-8);
    row-gap: 0;
    margin-top: var(--space-3);
  }

  /* Place each cell explicitly via data-attrs */
  .exp-tracks > [data-col="1"] { grid-column: 1; }
  .exp-tracks > [data-col="2"] { grid-column: 2; }
  .exp-tracks > .track-head    { grid-row: 1; }
  .exp-tracks > .entry[data-row="2"] { grid-row: 2; }
  .exp-tracks > .entry[data-row="3"] { grid-row: 3; }
  .exp-tracks > .entry[data-row="4"] { grid-row: 4; }
  .exp-tracks > .entry[data-row="5"] { grid-row: 5; }
  .exp-tracks > .entry[data-row="6"] { grid-row: 6; }

  /* ─── Track header ────────────────────────────────────────── */
  .track-head {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-bottom: 14px;
    margin-bottom: var(--space-3);
    border-bottom: 1px solid var(--rule);
    min-width: 0;
  }

  .track-glyph {
    color: var(--primary-soft);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .track-glyph-study {
    color: var(--text-muted);
  }

  .track-count {
    margin-left: auto;
    color: var(--text-muted);
    font-size: 11px;
    letter-spacing: 0.12em;
  }

  /* Pulse dot in column header — slightly smaller (6px) */
  .track-pulse {
    position: relative;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--amber);
    flex-shrink: 0;
    box-shadow: 0 0 8px rgba(245, 158, 11, 0.55);
  }

  .track-pulse::after {
    content: "";
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    border: 1px solid var(--amber);
    opacity: 0;
    animation: exp-pulse 2.4s ease-out infinite;
  }

  /* ─── Entry ──────────────────────────────────────────────── */
  .entry {
    padding-block: var(--space-3) var(--space-5);
    border-top: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
    transition: padding-left 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* First entry in EACH column (row 2) drops its top border so the
     header's bottom rule is the only line. */
  .entry[data-row="2"] {
    border-top: none;
    padding-top: 4px;
  }

  .entry:hover .entry-role {
    color: var(--primary-soft);
  }

  /* ─── Meta row (period + Current pill) ────────────────────── */
  .entry-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 4px;
  }

  .entry-period {
    color: var(--text-muted);
    font-size: var(--text-mono-s);
    letter-spacing: 0.08em;
    font-variant-numeric: tabular-nums;
  }

  .entry-current {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  /* Pulse dot to the LEFT of "Current" — slightly larger (8px) */
  .entry-pulse {
    position: relative;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--amber);
    flex-shrink: 0;
    box-shadow: 0 0 10px rgba(245, 158, 11, 0.55);
  }

  .entry-pulse::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid var(--amber);
    opacity: 0;
    animation: exp-pulse 2.4s ease-out infinite;
  }

  .entry-current-label {
    color: var(--amber);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  @keyframes exp-pulse {
    0%   { transform: scale(0.6); opacity: 0.55; }
    80%  { transform: scale(1.7); opacity: 0;    }
    100% { transform: scale(1.7); opacity: 0;    }
  }

  /* ─── Body ────────────────────────────────────────────────── */
  .entry-role {
    font-family: var(--font-display);
    font-size: clamp(22px, 1.9vw, 26px);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.15;
    transition: color 200ms ease;
  }

  .entry-company {
    font-size: var(--text-body-m);
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .entry-company-name {
    color: var(--text);
    font-weight: 500;
  }

  .entry-divider {
    color: var(--rule);
  }

  .entry-location {
    color: var(--text-muted);
    letter-spacing: 0.08em;
    font-size: var(--text-mono-s);
  }

  .entry-desc {
    color: var(--text-muted);
    font-size: var(--text-body-m);
    line-height: 1.6;
    max-width: 56ch;
    margin-top: 2px;
  }

  /* ─── Stacked layout (≤900px — narrow desktop + tablet + mobile) ──
     Switch to a single-column flow. Reorder by column then row using
     CSS `order`: all Work cells first (header + entries), then all
     Study cells. The Study header sits directly above its entries
     with extra breathing room and a short top accent rule so the
     boundary reads as deliberate. */
  @media (max-width: 900px) {
    .exp-tracks {
      grid-template-columns: 1fr;
      column-gap: 0;
    }

    /* Disable the desktop row-pinning — match the explicit-row
       selectors' specificity (0,2,1) so these resets actually win. */
    .exp-tracks > .track-head[data-col],
    .exp-tracks > .entry[data-row] {
      grid-column: 1;
      grid-row: auto;
    }

    /* Order: Work header → Work entries → Study header → Study entries */
    .exp-tracks > [data-col="1"].track-head           { order: 0; }
    .exp-tracks > [data-col="1"].entry[data-row="2"]  { order: 1; }
    .exp-tracks > [data-col="1"].entry[data-row="3"]  { order: 2; }
    .exp-tracks > [data-col="1"].entry[data-row="4"]  { order: 3; }
    .exp-tracks > [data-col="1"].entry[data-row="5"]  { order: 4; }
    .exp-tracks > [data-col="1"].entry[data-row="6"]  { order: 5; }

    .exp-tracks > [data-col="2"].track-head {
      order: 10;
      position: relative;
      margin-top: var(--space-8);
      padding-top: var(--space-5);
    }
    .exp-tracks > [data-col="2"].track-head::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 56px;
      height: 1px;
      background: linear-gradient(
        to right,
        var(--rule) 0%,
        var(--rule) 60%,
        transparent 100%
      );
    }
    .exp-tracks > [data-col="2"].entry[data-row="2"]  { order: 11; }
    .exp-tracks > [data-col="2"].entry[data-row="3"]  { order: 12; }
    .exp-tracks > [data-col="2"].entry[data-row="4"]  { order: 13; }
    .exp-tracks > [data-col="2"].entry[data-row="5"]  { order: 14; }
    .exp-tracks > [data-col="2"].entry[data-row="6"]  { order: 15; }
  }

  /* ─── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .exp {
      padding-block: var(--space-8) var(--space-8);
    }

    .exp-header {
      grid-template-columns: 1fr;
      gap: var(--space-3);
      align-items: start;
    }

    .exp-heading { grid-column: 1 / -1; font-size: 40px; }
    .exp-lede    { grid-column: 1 / -1; justify-self: start; }

    .entry-role {
      font-size: 22px;
    }
  }
</style>

<script>
  // Early reveal for the work/study tracks — triggers ~4vh before the global
  // observer (rootMargin bottom -2% vs the global -6%). Only adds is-visible;
  // removal is handled by the global observer in index.astro which has the
  // debounce + offscreen gate logic.
  const el = document.querySelector('[data-reveal-exp]');
  if (el && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          requestAnimationFrame(() => requestAnimationFrame(() => {
            el.classList.add('is-visible');
          }));
        }
      },
      { rootMargin: '-8% 0px -2% 0px', threshold: 0.01 }
    ).observe(el);
  }
</script>
