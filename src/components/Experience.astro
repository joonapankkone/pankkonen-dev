---
// Experience — Section 02
// Unified timeline: work and studies together.
// Ref: DESIGN_SPEC.md §4, §5, §6, §7.

type Entry = {
  period: string;
  role: string;
  company: string;
  location?: string;
  description?: string;
  current?: boolean;
  kind: 'work' | 'study';
};

const entries: Entry[] = [
  {
    period: '02/2026 — 09/2026',
    role: 'IT Trainee',
    company: 'Harvia',
    location: 'Muurame, FI',
    description:
      'IT administration at a publicly-listed manufacturer — Intune fleet management, ERP system support across production operations, service-desk coverage, and a hand in larger IT projects across the company.',
    current: true,
    kind: 'work',
  },
  {
    period: '09/2024 →',
    role: 'Road Closing',
    company: 'Toyota Gazoo Racing',
    description:
      'Part of the test-stage crew for Toyota Gazoo Racing — closing and securing special stages before driver runs. Safety-critical work in pre-event preparation.',
    current: true,
    kind: 'work',
  },
  {
    period: '08/2023 →',
    role: 'B.Eng. Information Technology',
    company: 'JAMK University of Applied Sciences',
    location: 'Jyväskylä, FI',
    description:
      'Advanced programming track with a specialisation in AI and data analytics — CRISP-DM pipelines, large-scale ML, DevOps. Expected graduation 05/2027.',
    current: true,
    kind: 'study',
  },
  {
    period: '08/2016 — 05/2019',
    role: 'Vocational ICT',
    company: 'Sedu, Lapua',
    location: 'Lapua, FI',
    description:
      'Vocational qualification in Information and Communications Technology.',
    kind: 'study',
  },
];
---

<section class="exp" id="experience" aria-labelledby="exp-heading">
  <div class="container exp-wrap">

    <header class="exp-header">
      <p class="section-index mono" data-reveal>01 · Experience</p>
      <h2 class="exp-heading" id="exp-heading" data-reveal data-reveal-delay="1">
        A path through<br />
        <span class="exp-accent">data, systems</span> and
        <span class="exp-accent">speed</span>.
      </h2>
      <p class="exp-lede" data-reveal data-reveal-delay="2">
        Work and study across IT operations, software engineering and AI —
        and a recurring test-stage role with Toyota Gazoo Racing.
      </p>
    </header>

    <ol class="timeline" role="list">
      {entries.map((e, i) => (
        <li class="tl-entry" data-kind={e.kind} data-current={e.current ? 'true' : 'false'} data-reveal data-reveal-delay={String(i + 1)}>
          <div class="tl-rail" aria-hidden="true">
            <span class="tl-node">
              {e.current && <span class="tl-node-pulse"></span>}
            </span>
          </div>

          <div class="tl-meta">
            <span class="mono tl-period">{e.period}</span>
            <span class={`mono tl-kind tl-kind-${e.kind}`}>
              {e.kind === 'work' ? '◆ Work' : '◇ Study'}
            </span>
            {e.current && <span class="mono tl-chip">Current</span>}
          </div>

          <div class="tl-body">
            <h3 class="tl-role">{e.role}</h3>
            <p class="tl-company">
              <span class="tl-company-name">{e.company}</span>
              {e.location && <span class="tl-divider" aria-hidden="true">·</span>}
              {e.location && <span class="tl-location mono">{e.location}</span>}
            </p>
            {e.description && <p class="tl-desc">{e.description}</p>}
          </div>
        </li>
      ))}
    </ol>

  </div>
</section>

<style>
  /* ─── Layout ──────────────────────────────────────────────── */
  .exp {
    padding-block: var(--space-13) var(--space-13);
    position: relative;
  }

  .exp-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-8);
  }

  /* ─── Header ──────────────────────────────────────────────── */
  .exp-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-8);
    align-items: end;
    margin-bottom: var(--space-8);
  }

  .exp-header .section-index {
    grid-column: 1 / -1;
    margin-bottom: var(--space-3);
  }

  .exp-heading {
    grid-column: 1 / 2;
    font-size: var(--text-display-l);
    color: var(--text);
    line-height: 1.02;
  }

  .exp-accent {
    color: var(--primary-soft);
    font-style: italic;
    font-weight: 300;
  }

  .exp-lede {
    grid-column: 2 / 3;
    color: var(--text-muted);
    font-size: var(--text-body-l);
    line-height: 1.55;
    max-width: 46ch;
    justify-self: end;
    padding-bottom: 6px;
  }

  /* ─── Timeline ────────────────────────────────────────────── */
  .timeline {
    list-style: none;
    padding-left: 0;
    margin-left: clamp(0px, 8vw, 90px);
    margin-right: clamp(0px, 4vw, 40px);
  }

  .tl-entry {
    display: grid;
    grid-template-columns: 180px 32px minmax(0, 1fr);
    gap: var(--space-5);
    padding-block: var(--space-5) var(--space-8);
    position: relative;
    align-items: start;
    transition:
      background-color 240ms ease,
      opacity 750ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 750ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tl-entry:last-child { padding-bottom: 0; }

  /* Hover state — subtle warm-up on the entire row */
  .tl-entry:hover .tl-role {
    color: var(--primary-soft);
  }
  .tl-entry:hover .tl-node {
    transform: scale(1.15);
    border-color: var(--primary-soft);
  }

  /* ─── Rail (vertical line + node) ─────────────────────────── */
  .tl-rail {
    grid-column: 2 / 3;
    position: relative;
    justify-self: center;
    width: 1px;
    align-self: stretch;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--rule) 10%,
      var(--rule) 90%,
      transparent 100%
    );
    min-height: 100%;
  }

  /* Hide the bottom of the last rail so the line doesn't dangle */
  .tl-entry:last-child .tl-rail {
    background: linear-gradient(
      to bottom,
      var(--rule) 0%,
      var(--rule) 40%,
      transparent 100%
    );
  }
  .tl-entry:first-child .tl-rail {
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--rule) 20%,
      var(--rule) 90%,
      transparent 100%
    );
  }

  .tl-node {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--bg);
    border: 1.5px solid var(--text-muted);
    box-shadow: 0 0 0 4px var(--bg);
    transition: transform 240ms ease, border-color 240ms ease, background 240ms ease;
    z-index: 2;
  }

  /* Current entry — amber filled node with soft pulse */
  .tl-entry[data-current='true'] .tl-node {
    background: var(--amber);
    border-color: var(--amber);
    box-shadow:
      0 0 0 4px var(--bg),
      0 0 16px rgba(245, 158, 11, 0.45);
  }

  .tl-node-pulse {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid var(--amber);
    opacity: 0;
    animation: tl-pulse 2.4s ease-out infinite;
  }

  @keyframes tl-pulse {
    0%   { transform: scale(0.7); opacity: 0.55; }
    80%  { transform: scale(1.6); opacity: 0; }
    100% { transform: scale(1.6); opacity: 0; }
  }

  /* ─── Meta column ─────────────────────────────────────────── */
  .tl-meta {
    grid-column: 1 / 2;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 6px;
  }

  .tl-period {
    color: var(--text);
    font-size: var(--text-mono-s);
    letter-spacing: 0.08em;
    font-variant-numeric: tabular-nums;
  }

  .tl-kind {
    display: inline-block;
    color: var(--text-muted);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .tl-kind-work   { color: var(--primary-soft); }
  .tl-kind-study  { color: var(--text-muted); }

  .tl-chip {
    display: inline-block;
    align-self: flex-start;
    padding: 3px 8px;
    border: 1px solid rgba(245, 158, 11, 0.35);
    border-radius: 999px;
    color: var(--amber);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: rgba(245, 158, 11, 0.06);
  }

  /* ─── Body ────────────────────────────────────────────────── */
  .tl-body {
    grid-column: 3 / 4;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .tl-role {
    font-family: var(--font-display);
    font-size: clamp(26px, 2.6vw, 34px);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.1;
    transition: color 200ms ease;
  }

  .tl-company {
    font-size: var(--text-body-m);
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tl-company-name {
    color: var(--text);
    font-weight: 500;
  }

  .tl-divider {
    color: var(--rule);
  }

  .tl-location {
    color: var(--text-muted);
    letter-spacing: 0.08em;
    font-size: var(--text-mono-s);
  }

  .tl-desc {
    color: var(--text-muted);
    font-size: var(--text-body-m);
    line-height: 1.6;
    max-width: 56ch;
    margin-top: 2px;
  }

  /* ─── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .exp {
      padding-block: var(--space-8) var(--space-8);
    }

    .exp-header {
      grid-template-columns: 1fr;
      gap: var(--space-3);
      align-items: start;
    }

    .exp-heading { grid-column: 1 / -1; font-size: 40px; }
    .exp-lede    { grid-column: 1 / -1; justify-self: start; }

    .timeline {
      margin-inline: 0;
    }

    .tl-entry {
      grid-template-columns: 24px minmax(0, 1fr);
      gap: var(--space-3);
      padding-block: var(--space-3) var(--space-5);
    }

    .tl-rail {
      grid-column: 1 / 2;
      grid-row: 1 / span 2;
    }

    .tl-meta {
      grid-column: 2 / 3;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 10px;
      padding-top: 4px;
    }

    .tl-body {
      grid-column: 2 / 3;
    }

    .tl-role {
      font-size: 24px;
    }
  }
</style>
