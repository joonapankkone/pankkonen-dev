---
// ProjectsDivider — Classical Centerpiece between Stack and Projects.
//
// Visual: italic § glyph centered, twin hairlines emanate from it
// outward all the way to the container edges (matching the Stack
// divider's full-width hairline). The lines are gradients that begin
// amber-bright at the §-end and fade through rule-grey to transparent
// at the far edges — the glow lives ONLY in the lines, not as a
// rectangular halo behind the glyph.
//
// Uses [data-rule-reveal] so the existing IO picks it up. Sweep styles
// in global.css are scoped to `.section-divider`, which this does not
// carry — it brings its own animation only.

interface Props {
  mark?: string;   // glyph rendered in the centre, default "§"
}

const { mark = '§' } = Astro.props;
---

<div class="proj-divider" data-rule-reveal aria-hidden="true">
  <div class="pd-inner">
    <span class="pd-line pd-line-l"></span>
    <span class="pd-mark">{mark}</span>
    <span class="pd-line pd-line-r"></span>
  </div>
</div>

<style>
  /* ─── Outer band ───────────────────────────────────────────── */
  .proj-divider {
    position: relative;
    width: 100vw;
    max-width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding-inline: 0;
    height: 100px;
    display: grid;
    place-items: center;
    pointer-events: none;
    overflow: visible;
    box-sizing: border-box;
  }

  /* Capped inner row keeps the rules editorial-length on ultrawide. */
  .pd-inner {
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--gutter);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  /* ─── Hairlines — amber-bright near §, fading to transparent ── */
  /* Each line spans flex:1 so together they fill the inner container
     width (minus the § + its padding) — same horizontal reach as the
     Stack divider's hairline. Lines animate scaleX from the §-end out
     so the warmth visually "sheds" outward from the glyph. The amber
     glow is concentrated in the inner ~15% near §; the rest fades
     through whisper-grey to transparent at the far edges. */
  .pd-line {
    flex: 1;
    height: 1px;
    transform: scaleX(0);
    transition: transform 980ms cubic-bezier(0.16, 1, 0.3, 1) 220ms;
  }

  .pd-line-l {
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(232, 237, 245, 0.10) 50%,
      rgba(232, 237, 245, 0.16) 75%,
      rgba(245, 158, 11, 0.30) 88%,
      rgba(245, 158, 11, 0.55) 100%
    );
    transform-origin: right;
  }

  .pd-line-r {
    background: linear-gradient(
      90deg,
      rgba(245, 158, 11, 0.55) 0%,
      rgba(245, 158, 11, 0.30) 12%,
      rgba(232, 237, 245, 0.16) 25%,
      rgba(232, 237, 245, 0.10) 50%,
      transparent 100%
    );
    transform-origin: left;
  }

  .proj-divider.is-visible .pd-line {
    transform: scaleX(1);
  }

  /* ─── Glyph — italic § with display optical size ───────────── */
  /* No halo behind the glyph — the glow lives entirely in the line
     gradients. The glyph itself just appears with a small scale-in. */
  .pd-mark {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: 28px;
    line-height: 1;
    color: var(--amber);
    /* Display optical size — taller, more refined italic at this scale. */
    font-variation-settings: "opsz" 144;
    flex-shrink: 0;
    padding: 0 22px;
    opacity: 0;
    transform: scale(0.78);
    transition:
      opacity 520ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 660ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .proj-divider.is-visible .pd-mark {
    opacity: 1;
    transform: scale(1);
  }

  /* ─── Mobile ───────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .proj-divider { height: 84px; }
    .pd-mark { font-size: 24px; padding: 0 16px; }
  }

  /* ─── Reduced motion ───────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .pd-line,
    .pd-mark {
      transition-duration: 1ms !important;
      transition-delay: 0ms !important;
    }
  }
</style>
