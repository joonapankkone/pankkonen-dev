---
import BeyondTopDivider from './BeyondTopDivider.astro';
// Beyond the Code — Section 04
// Full-bleed background video stage (treatment 3A) on desktop,
// letterbox card on mobile. Video gated by IntersectionObserver
// and respects prefers-reduced-motion.
// Video assets live in public/: btc-sim.{webm,mp4}, btc-sim-mobile.mp4,
// btc-sim-poster.jpg. See docs/superpowers/specs/2026-05-01-beyond-fullbleed-and-copy-design.md.
---

<!-- Divider: projects → beyond the code (desktop only — hidden on mobile) -->
<div class="btd-desktop-wrap">
  <BeyondTopDivider />
</div>

<!-- ── 04 · BEYOND THE CODE — full-bleed frame + 16:9 video stage ── -->
<section class="beyond" id="beyond" aria-label="Beyond the Code">

  <!-- Mobile-only: chapter mark + headline (above divider + video) -->
  <div class="beyond__copy-top">
    <p class="beyond__chapter">04 · Beyond the Code</p>
    <h2 class="beyond__heading">
      A competitive mindset,<br />
      <em>applied beyond code</em>.
    </h2>
  </div>

  <!-- Mobile-only: animated sweep divider right above the video -->
  <div class="beyond__divider-wrap">
    <BeyondTopDivider />
  </div>

  <div class="beyond-stage">
    <video
      class="beyond-video"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      poster="/btc-sim-poster.jpg"
      aria-hidden="true"
      data-beyond-video
    >
      <source src="/btc-sim-mobile.mp4" type="video/mp4" media="(max-width: 768px)" />
      <source src="/btc-sim.mp4" type="video/mp4" />
    </video>
    <div class="beyond-scrim" aria-hidden="true"></div>

    <!-- Mobile-only: bottom fade that dissolves into --bg -->
    <div class="beyond__media-fade" aria-hidden="true"></div>

    <!-- Desktop-only: stage banner (top-right) -->
    <div class="beyond-banner" aria-hidden="true">
      <span class="beyond-banner-dot"></span>
      <span class="mono">ESPORTS WRC KNOCKOUT TROPHY '23</span>
    </div>

    <!-- Desktop-only: chapter mark (top-left) -->
    <div class="beyond-chapter">
      <p class="mono">04 · Beyond the Code</p>
    </div>

    <!-- Mobile-only: race tag overlay (top-left, inside dark veil) -->
    <div class="beyond__meta" aria-hidden="true">
      <span class="beyond__race">
        <span class="beyond__dot" aria-hidden="true"></span>
        ESPORTS WRC '23
      </span>
    </div>

    <!-- Desktop-only: text content anchored to stage bottom -->
    <div class="beyond-inner">
      <div class="container">
        <h2 class="beyond-heading" data-reveal>
          A competitive mindset,<br />
          <span class="beyond-accent">applied beyond code.</span>
        </h2>
        <p class="beyond-para" data-reveal data-reveal-delay="1">
          Two-time DiRT Rally world champion with a competitive sim racing background.
          These days I keep busy with gym training, outdoor activities, open water swimming, and Latin dance.
        </p>
      </div>
    </div>
  </div>

  <!-- Mobile-only: paragraph pulled up into the bottom-fade tail -->
  <div class="beyond__copy-bottom">
    <p class="beyond__lede">
      Two-time DiRT Rally world champion with a competitive sim racing background.
      These days I keep busy with gym training, outdoor activities, open water swimming, and Latin dance.
    </p>
  </div>

</section>

<style>
  /* ─── 04 · Beyond the Code — outer frame + 16:9 stage ────── */
  .beyond {
    width: 100vw;
    max-width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding-inline: 0;
    display: flex;
    justify-content: center;
  }

  .beyond-stage {
    position: relative;
    width: min(100vw, calc(85vh * 16 / 9));
    aspect-ratio: 16 / 9;
    overflow: hidden;
    isolation: isolate;
  }

  .beyond-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    display: block;
  }

  .beyond-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(8, 8, 10, 0.35) 0%,
      rgba(8, 8, 10, 0.55) 40%,
      rgba(8, 8, 10, 0.92) 85%,
      rgba(8, 8, 10, 0.96) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .beyond-inner {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-block-end: 58px;
  }

  .beyond-inner > .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .beyond-inner .section-index {
    margin: 0;
  }

  .beyond-inner .section-index::before {
    display: none;
  }

  .beyond-heading {
    font-size: var(--text-display-l);
    color: var(--text);
    line-height: 1.02;
    /* Bottom-only: nothing above (chapter mark is absolutely positioned).
       Matches Projects/Experience/Stack/Contact heading rhythm — flush
       top, gap-controlled bottom.                                       */
    margin: 0 0 var(--space-5);
  }

  .beyond-accent {
    color: var(--primary-soft);
    font-style: italic;
    font-weight: 300;
  }

  .beyond-para {
    color: var(--text-muted);
    font-size: var(--text-body-l);
    line-height: 1.65;
    max-width: 56ch;
    margin: 0;
  }

  /* ─── Stage banner (top-right, desktop only) ────────────── */
  .beyond-banner {
    position: absolute;
    top: 32px;
    right: 40px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 8px 14px;
    border: 1px solid rgba(245, 158, 11, 0.35);
    background: rgba(245, 158, 11, 0.06);
    border-radius: 4px;
    backdrop-filter: blur(8px);
    color: var(--amber);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .beyond-banner-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--amber);
    box-shadow: 0 0 8px rgba(245, 158, 11, 0.7);
    flex-shrink: 0;
  }

  /* ─── Chapter mark (top-left, desktop only) ─────────────── */
  .beyond-chapter {
    position: absolute;
    top: 32px;
    left: 40px;
    z-index: 3;
    color: rgba(232, 237, 245, 0.7);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 11px;
  }

  .beyond-chapter p {
    margin: 0;
  }

  /* ─── Mobile-only elements — hidden on desktop ───────────── */
  .beyond__copy-top,
  .beyond__divider-wrap,
  .beyond__meta,
  .beyond__media-fade,
  .beyond__copy-bottom {
    display: none;
  }

  /* ─── Desktop-only wrapper: section-separator divider ───── */
  .btd-desktop-wrap {
    display: block;
  }

  /* ─── Scroll reveal ──────────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-reveal][data-reveal-delay="1"] { transition-delay: 80ms; }
  [data-reveal][data-reveal-delay="2"] { transition-delay: 160ms; }
  [data-reveal][data-reveal-delay="3"] { transition-delay: 240ms; }
  [data-reveal][data-reveal-delay="4"] { transition-delay: 320ms; }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Mobile ≤ 768px ─────────────────────────────────────── */
  @media (max-width: 768px) {

    /* Stack the section vertically; full-bleed with no side padding */
    .beyond {
      flex-direction: column;
      justify-content: flex-start;
      width: 100vw;
      max-width: 100vw;
      margin-inline: calc(50% - 50vw);
      padding-inline: 0;
      padding-block: 0;
      background: var(--bg);
    }

    /* Desktop section-separator hidden on mobile */
    .btd-desktop-wrap {
      display: none;
    }

    /* Mobile-only: animated sweep divider right above the video */
    .beyond__divider-wrap {
      display: block;
    }

    /* ── Video block — portrait 4/5, full-bleed ─────────── */
    .beyond-stage {
      position: relative;
      width: 100%;
      aspect-ratio: 4 / 5;
      overflow: hidden;
      isolation: isolate;
    }

    /* Scrim — kept on mobile so heading text is readable */
    .beyond-scrim {
      display: block;
    }

    /* Slight grade to compensate for removed scrim */
    .beyond-video {
      filter: contrast(1.05) saturate(0.9) brightness(0.85);
    }

    /* Mobile bottom fade — strong tail dissolving into --bg */
    .beyond__media-fade {
      display: block;
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      background: linear-gradient(
        180deg,
        rgba(8, 8, 10, 0)    0%,
        rgba(8, 8, 10, 0.10) 50%,
        rgba(8, 8, 10, 0.60) 85%,
        var(--bg)           100%
      );
    }

    /* Desktop-only stage decorations: hidden on mobile */
    .beyond-chapter,
    .beyond-banner {
      display: none;
    }

    /* Heading overlay — visible on mobile, anchored to video bottom.
       padding-block-end raised from 28 → 45 to lift the paragraph
       ~17px off the bottom edge.                                       */
    .beyond-inner {
      display: flex;
      padding-block-end: 45px;
    }

    /* Gap controls heading↔paragraph separation on mobile. Paragraph
       is anchored to video bottom (flex-end + padding-block-end), so
       gap = how far ABOVE the paragraph the heading sits. Reduced
       80 → 63 to compensate for the +17 padding bump above, keeping
       the heading at the same vertical position while the paragraph
       moves up 17px.                                                   */
    .beyond-inner > .container {
      gap: 63px;
    }

    /* Mobile heading: tuned to fit "A competitive mindset," on a single
       line at iPhone 14 Pro width (393 → ~29.5px). Previous 35px wrapped
       mid-phrase. Floor 28px keeps it readable on iPhone SE; cap 36px
       keeps it from re-introducing wrap on tablets. -0.025em letter-
       spacing buys a few extra pixels of horizontal room.               */
    .beyond-heading {
      font-size: clamp(28px, 7.5vw, 36px);
      line-height: 1.1;
      letter-spacing: -0.025em;
      margin: 0;
    }

    /* Show paragraph in the fade zone at the video bottom */
    .beyond-para {
      display: block;
      font-size: 15px;
      line-height: 1.55;
      max-width: 100%;
    }

    /* Mobile race tag — top-LEFT, inside dark gradient veil */
    .beyond__meta {
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      z-index: 3;
      padding: 14px 20px;
      background: linear-gradient(
        180deg,
        rgba(8, 8, 10, 0.85) 0%,
        rgba(8, 8, 10, 0)    100%
      );
    }

    .beyond__race {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--amber);
      white-space: nowrap;
    }

    .beyond__dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--amber);
      box-shadow: 0 0 6px rgba(245, 158, 11, 0.7);
      flex-shrink: 0;
    }

    /* Paragraph now lives inside the video overlay — hide duplicate */
    .beyond__copy-bottom {
      display: none;
    }

    .beyond__lede {
      font-family: var(--font-sans);
      font-size: 15px;
      line-height: 1.6;
      color: var(--text-muted);
      margin: 0;
      max-width: 40ch;
    }
  }
</style>

<script>
  // Gates the Beyond background video on viewport entry/exit:
  //   - Plays when the section is (about to be) visible
  //   - Pauses when fully off-screen (saves CPU + battery)
  //   - Respects prefers-reduced-motion: never starts the clip,
  //     leaves the poster image as the visible state
  const initBeyondVideo = () => {
    const video = document.querySelector<HTMLVideoElement>('[data-beyond-video]');
    if (!video) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) {
      // Strip autoplay so the browser doesn't begin playback even briefly,
      // and explicitly pause in case some attribute hot-path already kicked in.
      video.removeAttribute('autoplay');
      try { video.pause(); } catch {}
      return;
    }

    const section = video.closest('section');
    if (!section) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // play() returns a Promise that may reject under iOS autoplay
            // policy — swallow it; the user will still see the poster.
            const p = video.play();
            if (p && typeof p.catch === 'function') p.catch(() => {});
          } else {
            video.pause();
          }
        });
      },
      {
        rootMargin: '10% 0px 10% 0px',
        threshold: 0,
      }
    );

    io.observe(section);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBeyondVideo, { once: true });
  } else {
    initBeyondVideo();
  }
</script>
