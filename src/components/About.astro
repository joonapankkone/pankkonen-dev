---
import BeyondTopDivider from './BeyondTopDivider.astro';
// Beyond the Code — Section 04
// Full-bleed background video stage (treatment 3A) on desktop,
// letterbox card on mobile. Video gated by IntersectionObserver
// and respects prefers-reduced-motion.
// Video assets live in public/: btc-sim.{webm,mp4}, btc-sim-mobile.mp4,
// btc-sim-poster.jpg. See docs/superpowers/specs/2026-05-01-beyond-fullbleed-and-copy-design.md.
---

<!-- Divider: projects → beyond the code (video-width amber sweep) -->
<BeyondTopDivider />

<!-- ── 04 · BEYOND THE CODE — full-bleed frame + 16:9 video stage ── -->
<section class="beyond" id="beyond">
  <div class="beyond-stage">
    <video
      class="beyond-video"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      poster="/btc-sim-poster.jpg"
      aria-hidden="true"
      data-beyond-video
    >
      <source src="/btc-sim-mobile.mp4" type="video/mp4" media="(max-width: 768px)" />
      <source src="/btc-sim.mp4" type="video/mp4" />
    </video>
    <div class="beyond-scrim" aria-hidden="true"></div>

    <!-- Stage banner: event label (top-right) -->
    <div class="beyond-banner" aria-hidden="true">
      <span class="beyond-banner-dot"></span>
      <span class="mono">ESPORTS WRC KNOCKOUT TROPHY '23</span>
    </div>

    <!-- Chapter mark (top-left) -->
    <div class="beyond-chapter">
      <p class="mono">04 / 05 · Beyond the Code</p>
    </div>

    <div class="beyond-inner">
      <div class="container">
        <h2 class="beyond-heading" data-reveal>
          A competitive mindset,<br />
          <span class="beyond-accent">applied beyond code</span>.
        </h2>
        <p class="beyond-para" data-reveal data-reveal-delay="1">
          Two-time DiRT Rally world champion with a competitive sim racing background.
          These days, gym training, outdoor activities, open water swimming, and Latin dance.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* ─── 04 · Beyond the Code — outer frame + 16:9 stage ────── */
  /* Outer frame is full-bleed (100vw); stage caps width so the video
     always renders at 16:9 with no crop, regardless of viewport.
     On screens wider than calc(85vh * 16/9), the page bg shows on
     the sides of the stage — same pattern as Linear / Vercel hero
     sections. On screens narrower than that threshold, stage fills
     the viewport edge to edge. */
  .beyond {
    width: 100vw;
    max-width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding-inline: 0;
    display: flex;
    justify-content: center;
  }

  .beyond-stage {
    position: relative;
    width: min(100vw, calc(85vh * 16 / 9));
    aspect-ratio: 16 / 9;
    overflow: hidden;
    isolation: isolate;
  }

  .beyond-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    display: block;
  }

  .beyond-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(8, 8, 10, 0.35) 0%,
      rgba(8, 8, 10, 0.55) 40%,
      rgba(8, 8, 10, 0.92) 85%,
      rgba(8, 8, 10, 0.96) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .beyond-inner {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    /* 58px — close to the stage edge but with enough room to breathe */
    padding-block-end: 58px;
  }

  .beyond-inner > .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .beyond-inner .section-index {
    margin: 0;
  }

  /* The chapter mark overlay already labels the section —
     suppress the ::before rule-line on the inner copy so it
     doesn't double up with the global .section-index style. */
  .beyond-inner .section-index::before {
    display: none;
  }

  .beyond-heading {
    font-size: var(--text-display-l);
    color: var(--text);
    line-height: 1.02;
    margin: var(--space-2) 0 var(--space-5);
  }

  .beyond-accent {
    color: var(--primary-soft);
    font-style: italic;
    font-weight: 300;
  }

  .beyond-para {
    color: var(--text-muted);
    font-size: var(--text-body-l);
    line-height: 1.65;
    max-width: 56ch;
    margin: 0;
  }

  /* ─── Stage banner (top-right) ──────────────────────────── */
  .beyond-banner {
    position: absolute;
    top: 32px;
    right: 40px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 8px 14px;
    border: 1px solid rgba(245, 158, 11, 0.35);
    background: rgba(245, 158, 11, 0.06);
    border-radius: 4px;
    backdrop-filter: blur(8px);
    color: var(--amber);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .beyond-banner-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--amber);
    box-shadow: 0 0 8px rgba(245, 158, 11, 0.7);
    flex-shrink: 0;
  }

  /* ─── Chapter mark (top-left) ────────────────────────────── */
  .beyond-chapter {
    position: absolute;
    top: 32px;
    left: 40px;
    z-index: 3;
    color: rgba(232, 237, 245, 0.7);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 11px;
  }

  .beyond-chapter p {
    margin: 0;
  }

  /* ─── Scroll reveal ──────────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-reveal][data-reveal-delay="1"] { transition-delay: 80ms; }
  [data-reveal][data-reveal-delay="2"] { transition-delay: 160ms; }
  [data-reveal][data-reveal-delay="3"] { transition-delay: 240ms; }
  [data-reveal][data-reveal-delay="4"] { transition-delay: 320ms; }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 768px) {
    /* Stage banner and chapter mark are redundant at mobile width */
    .beyond-banner,
    .beyond-chapter {
      display: none;
    }

    .about {
      padding-block: var(--space-8) var(--space-8);
    }

    .about-header {
      grid-template-columns: 1fr;
    }

    .about-heading {
      grid-column: 1 / -1;
    }

    .about-body {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    /* Beyond — revert to natural document flow on mobile (video on top, then text) */
    .beyond {
      width: 100%;
      max-width: 100%;
      margin-inline: 0;
      padding-inline: var(--space-5);
      padding-block: var(--space-8);
      display: block;
    }

    .beyond-stage {
      width: 100%;
      aspect-ratio: auto;
      overflow: visible;
      isolation: auto;
      display: flex;
      flex-direction: column;
      gap: var(--space-6);
    }

    .beyond-video {
      position: static;
      width: 100%;
      max-width: 480px;
      height: auto;
      aspect-ratio: 16 / 9;
      border-radius: 14px;
      box-shadow: 0 0 0 1px var(--rule);
      object-fit: cover;
      align-self: center;
    }

    .beyond-scrim {
      display: none;
    }

    .beyond-inner {
      position: static;
      padding-block-end: 0;
      display: block;
    }

    .beyond-inner > .container {
      gap: var(--space-3);
    }

    .beyond-inner .beyond-heading {
      margin-block: 0 var(--space-2);
    }
  }
</style>

<script>
  // Gates the Beyond background video on viewport entry/exit:
  //   - Plays when the section is (about to be) visible
  //   - Pauses when fully off-screen (saves CPU + battery)
  //   - Respects prefers-reduced-motion: never starts the clip,
  //     leaves the poster image as the visible state
  const initBeyondVideo = () => {
    const video = document.querySelector<HTMLVideoElement>('[data-beyond-video]');
    if (!video) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) {
      // Strip autoplay so the browser doesn't begin playback even briefly,
      // and explicitly pause in case some attribute hot-path already kicked in.
      video.removeAttribute('autoplay');
      try { video.pause(); } catch {}
      return;
    }

    const section = video.closest('section');
    if (!section) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // play() returns a Promise that may reject under iOS autoplay
            // policy — swallow it; the user will still see the poster.
            const p = video.play();
            if (p && typeof p.catch === 'function') p.catch(() => {});
          } else {
            video.pause();
          }
        });
      },
      {
        rootMargin: '10% 0px 10% 0px',
        threshold: 0,
      }
    );

    io.observe(section);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBeyondVideo, { once: true });
  } else {
    initBeyondVideo();
  }
</script>
