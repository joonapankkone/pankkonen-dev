---
// BeyondTopDivider — Amber rule at the top edge of the Beyond the Code video.
//
// Width: min(100vw, calc(85vh * 16 / 9)) — tracks .beyond-stage exactly.
// Centred within a 100vw outer wrapper (same pattern as .beyond).
//
// Animation: amber line sweeps left→right (scaleX from left, 1100ms ease-out),
// followed by a shimmer flash (70px element, 950ms linear) that travels
// the full inner width. Both animations REPLAY on every scroll pass via the
// [data-rule-reveal] / global IO pattern: removing is-visible resets the
// @keyframes (no fill-mode:forwards), re-adding it restarts from frame 0.
//
// Line is 2px tall with boosted amber opacity + a diffuse glow layer beneath
// for extra presence against the dark video stage.
---

<div class="beyond-top-rule" data-rule-reveal aria-hidden="true">
  <div class="btr-inner">
    <span class="btr-glow"></span>
    <span class="btr-line"></span>
    <span class="btr-sweep"></span>
  </div>
</div>

<style>
  /* ─── Outer wrapper — same pattern as .beyond ───────────── */
  .beyond-top-rule {
    display: flex;
    justify-content: center;
    width: 100vw;
    max-width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding-inline: 0;
    pointer-events: none;
  }

  /* ─── Inner — matches .beyond-stage width exactly ───────── */
  /* 2px tall so the line itself has more physical weight.      */
  .btr-inner {
    position: relative;
    width: min(100vw, calc(85vh * 16 / 9));
    height: 2px;
    overflow: hidden;   /* clips sweep shimmer to video-stage bounds */
  }

  /* ─── Diffuse glow layer — sits beneath the crisp line ──── */
  /* A 6px-tall blurred amber band that gives the line a warm   */
  /* LED-backlit feel. Animates in sync with the main line.     */
  .btr-glow {
    display: block;
    position: absolute;
    inset: -2px 0;
    height: 6px;
    background: linear-gradient(
      90deg,
      rgba(245, 158, 11, 0)    0%,
      rgba(245, 158, 11, 0.30)  6%,
      rgba(245, 158, 11, 0.22) 50%,
      rgba(245, 158, 11, 0.30) 94%,
      rgba(245, 158, 11, 0)   100%
    );
    filter: blur(2px);
    transform: scaleX(0);
    transform-origin: left;
  }

  .beyond-top-rule.is-visible .btr-glow {
    animation: btr-line-in 880ms ease-out forwards;
  }

  /* ─── Crisp amber hairline — sweeps left→right on reveal ── */
  /* scaleX(0→1) from left — feels like a scan drawing the line.*/
  /* Boosted opacity (0.80 peak) for clear presence on video.   */
  .btr-line {
    display: block;
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(245, 158, 11, 0.04)  0%,
      rgba(245, 158, 11, 0.80)  6%,
      rgba(245, 158, 11, 0.70) 50%,
      rgba(245, 158, 11, 0.80) 94%,
      rgba(245, 158, 11, 0.04) 100%
    );
    transform: scaleX(0);
    transform-origin: left;
  }

  /* ease-out (vs spring) gives a more deliberate, cinematic draw. */
  /* No fill-mode:forwards → snaps back to scaleX(0) on removal,  */
  /* so the animation replays cleanly on every re-entry.           */
  .beyond-top-rule.is-visible .btr-line {
    animation: btr-line-in 880ms ease-out forwards;
  }

  @keyframes btr-line-in {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  /* ─── Shimmer sweep ──────────────────────────────────────── */
  /* A 70px bright flash that travels the full btr-inner width.  */
  /* `left` property keyframes → "100%" resolves to btr-inner    */
  /* width, no JS measurement needed.                             */
  /*                                                              */
  /* Duration 1300ms, delay 500ms:                               */
  /*   - Shimmer starts when the line is ~31% extended            */
  /*   - Visible window (opacity on 10%→90%) = 80% × 950 ≈ 760ms  */
  /*   - Bright centre visible for the middle ~400ms of that pass */
  .btr-sweep {
    display: block;
    position: absolute;
    top: -1px;
    left: -180px;          /* starts fully off-screen left (wider element) */
    width: 180px;
    height: 4px;
    background: linear-gradient(
      90deg,
      transparent                    0%,
      rgba(245, 158, 11, 0.20)      12%,
      rgba(255, 220, 120, 0.55)     30%,
      rgba(255, 255, 255, 0.98)     50%,
      rgba(255, 220, 120, 0.55)     70%,
      rgba(245, 158, 11, 0.20)      88%,
      transparent                   100%
    );
    border-radius: 2px;
    filter: blur(0.6px);
    opacity: 0;
    pointer-events: none;
  }

  .beyond-top-rule.is-visible .btr-sweep {
    animation: btr-shimmer 760ms linear forwards;
    animation-delay: 460ms;
  }

  @keyframes btr-shimmer {
    0%   { left: -180px; opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { left: calc(100% + 180px); opacity: 0; }
  }

  /* ─── Reduced motion ─────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .btr-line,
    .btr-glow,
    .btr-sweep {
      animation-duration: 1ms !important;
      animation-delay:    0ms !important;
    }
  }
</style>
