---
// Stack — Section 04
// Technical skills by category. No skill bars — just honest labels.
// Ref: DESIGN_SPEC.md §4, §5, §6.

type Category = {
  index: string;
  title: string;
  subtitle: string;
  items: { name: string; note?: string }[];
};

const categories: Category[] = [
  {
    index: 'I',
    title: 'Data & ML',
    subtitle: 'Where the signal lives.',
    items: [
      { name: 'Python',       note: 'primary language'   },
      { name: 'pandas',       note: 'dataframe surgery'  },
      { name: 'polars',       note: 'large rowcounts'    },
      { name: 'scikit-learn', note: 'baselines + Cross Validation' },
      { name: 'Jupyter',      note: 'exploration'        },
    ],
  },
  {
    index: 'II',
    title: 'Web & Programming',
    subtitle: 'The surface area.',
    items: [
      { name: 'JavaScript',   note: 'scripting + interactivity' },
      { name: 'HTML',         note: 'standards-based'     },
      { name: 'CSS',          note: 'layout + motion'     },
      { name: 'SQL',          note: 'joins, windows, CTE' },
    ],
  },
  {
    index: 'III',
    title: 'Infrastructure',
    subtitle: 'Plumbing that keeps it running.',
    items: [
      { name: 'Docker',       note: 'local + prod parity'  },
      { name: 'Git',          note: 'branching + history' },
      { name: 'GitLab CI/CD', note: 'pipelines + runners'  },
      { name: 'Linux',        note: 'servers + scripting'  },
    ],
  },
  {
    index: 'IV',
    title: 'AI Workflow',
    subtitle: 'The pair across the desk.',
    items: [
      { name: 'Claude',         note: 'pair on big builds'    },
      { name: 'Claude Code',    note: 'agent at the keyboard' },
      { name: 'ChatGPT',        note: 'code + writing polish' },
      { name: 'GitHub Copilot', note: 'the office pair'       },
    ],
  },
];
---

<section class="stack" id="stack" aria-labelledby="stack-heading">
  <div class="container stack-wrap">

    <header class="stack-header">
      <p class="section-index mono" data-reveal>02 · Stack</p>
      <h2 class="stack-heading" id="stack-heading" data-reveal data-reveal-delay="1">
        Tools I reach for<br />
        <span class="stack-accent">without thinking.</span>
      </h2>
      <p class="stack-lede" data-reveal data-reveal-delay="2">
        The kit that shows up across coursework, client work and weekend builds —
        grouped by where each tool actually lives in the workflow.
      </p>
    </header>

    <div class="stack-grid">
      {categories.map((cat, i) => (
        <article class="cat" data-reveal data-reveal-delay={(i + 1).toString()}>
          <header class="cat-header">
            <span class="cat-index">{cat.index}</span>
            <div class="cat-titles">
              <h3 class="cat-title">{cat.title}</h3>
              <p class="cat-subtitle">{cat.subtitle}</p>
            </div>
          </header>

          <ul class="cat-list" role="list">
            {cat.items.map((item, j) => (
              <li class="cat-item" style={`--row:${j}`}>
                <span class="cat-item-idx mono">
                  {String(j + 1).padStart(2, '0')}
                </span>
                <span class="cat-item-name">{item.name}</span>
                {item.note && <span class="cat-item-note mono">{item.note}</span>}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  /* ─── Layout ──────────────────────────────────────────────── */
  .stack {
    padding-block: var(--space-13) var(--space-13);
    position: relative;
  }

  .stack-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-8);
  }

  /* ─── Header ──────────────────────────────────────────────── */
  .stack-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-8);
    align-items: end;
    margin-bottom: var(--space-5);
  }

  .stack-header .section-index {
    grid-column: 1 / -1;
    margin-bottom: var(--space-3);
  }

  .stack-heading {
    grid-column: 1 / 2;
    font-size: var(--text-display-l);
    color: var(--text);
    line-height: 1.02;
  }

  .stack-accent {
    color: var(--primary-soft);
    font-style: italic;
    font-weight: 300;
  }

  .stack-lede {
    grid-column: 2 / 3;
    color: var(--text-muted);
    font-size: var(--text-body-l);
    line-height: 1.55;
    max-width: 48ch;
    justify-self: end;
    padding-bottom: 6px;
  }

  /* ─── Category grid ───────────────────────────────────────── */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .cat {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: 16px;
    padding: var(--space-5) var(--space-5) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition:
      background 240ms ease,
      border-color 240ms ease,
      translate 220ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 750ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 750ms cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }

  .cat::before {
    /* soft blue glow in top-right corner */
    content: "";
    position: absolute;
    top: -80px;
    right: -80px;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: radial-gradient(
      circle at center,
      rgba(59, 130, 246, 0.12) 0%,
      rgba(59, 130, 246, 0) 70%
    );
    pointer-events: none;
    transition: opacity 300ms ease;
    opacity: 0.75;
  }

  .cat:hover {
    background: var(--surface-raised);
    border-color: rgba(96, 165, 250, 0.35);
    translate: 0 -2px;
  }

  .cat:hover::before { opacity: 1; }

  .cat-header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-3);
    align-items: center;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--rule);
  }

  .cat-index {
    font-family: var(--font-display);
    font-size: 56px;
    line-height: 0.9;
    color: var(--primary);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.02em;
    font-variant-numeric: lining-nums;
  }

  .cat-titles { display: flex; flex-direction: column; gap: 4px; }

  .cat-title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .cat-subtitle {
    color: var(--text-muted);
    font-size: var(--text-body-s);
    line-height: 1.4;
  }

  /* ─── Item list ───────────────────────────────────────────── */
  .cat-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 2px;
  }

  .cat-item {
    display: grid;
    grid-template-columns: 30px minmax(0, auto) minmax(0, 1fr);
    gap: 14px;
    align-items: baseline;
    padding: 12px 0;
    border-bottom: 1px dashed transparent;
    transition: border-color 200ms ease, padding-left 240ms ease;
    position: relative;
  }

  .cat-item + .cat-item {
    border-top: 1px solid var(--rule);
  }

  .cat:hover .cat-item {
    border-top-color: rgba(96, 165, 250, 0.18);
  }

  .cat-item::before {
    content: "";
    position: absolute;
    left: -8px;
    top: 50%;
    transform: translateY(-50%) scaleX(0);
    transform-origin: left center;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--primary);
    transition: transform 220ms ease;
  }

  .cat-item:hover::before {
    transform: translateY(-50%) scaleX(1);
  }

  .cat-item:hover {
    padding-left: 6px;
  }

  .cat-item-idx {
    color: var(--text-muted);
    font-size: 11px;
    letter-spacing: 0.08em;
    opacity: 0.6;
  }

  .cat-item-name {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .cat-item-note {
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-align: right;
    justify-self: end;
    max-width: 18ch;
    line-height: 1.35;
  }

  /* ─── Footer note ─────────────────────────────────────────── */
  .stack-footer {
    margin-top: var(--space-5);
    padding-top: var(--space-3);
    border-top: 1px solid var(--rule);
    max-width: 680px;
  }

  .stack-footnote {
    color: var(--text-muted);
    font-size: 12px;
    letter-spacing: 0.02em;
    line-height: 1.6;
  }

  .stack-footnote-dash { color: var(--primary); margin-right: 6px; }

  /* ─── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .stack-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }

  @media (max-width: 768px) {
    .stack {
      padding-block: var(--space-8);
    }

    .stack-header {
      grid-template-columns: 1fr;
      gap: var(--space-3);
      align-items: start;
    }

    .stack-heading {
      grid-column: 1 / -1;
      font-size: 40px;
    }

    .stack-lede {
      grid-column: 1 / -1;
      justify-self: start;
    }

    .cat { padding: var(--space-3) var(--space-3) var(--space-2); }

    .cat-index { font-size: 48px; }
    .cat-title { font-size: 22px; }
    .cat-item-note { max-width: 14ch; }
  }
</style>
