---
// Stack — Section 02
// Compact 4-column index. Vertical hairline rules between columns,
// monospace category numbers, dashed item dividers, mouse-following
// radial hover glow + 1px amber top-edge accent that draws on hover.
// Apple-product-page rhythm. Roughly 1/3 the vertical real estate
// of the previous card layout.
// Ref: DESIGN_SPEC.md §4, §5, §6.

type Category = {
  title: string;
  items: { name: string }[];
};

const categories: Category[] = [
  {
    title: 'Data & ML',
    items: [
      { name: 'Python' },
      { name: 'pandas' },
      { name: 'polars' },
      { name: 'scikit-learn' },
      { name: 'Jupyter' },
    ],
  },
  {
    title: 'Web & Programming',
    items: [
      { name: 'JavaScript' },
      { name: 'HTML' },
      { name: 'CSS' },
      { name: 'SQL' },
    ],
  },
  {
    title: 'Infrastructure',
    items: [
      { name: 'Docker' },
      { name: 'Git' },
      { name: 'GitLab CI/CD' },
      { name: 'Linux' },
    ],
  },
  {
    title: 'AI Workflow',
    items: [
      { name: 'Claude' },
      { name: 'Claude Code' },
      { name: 'ChatGPT' },
      { name: 'Copilot' },
    ],
  },
];
---

<section class="stack" id="stack" aria-labelledby="stack-heading">
  <div class="container stack-wrap">

    <header class="stack-header">
      <h2 class="stack-heading" id="stack-heading" data-reveal data-reveal-delay="1">
        Tools I reach for<br />
        <span class="stack-accent">without thinking.</span>
      </h2>
      <p class="stack-lede" data-reveal data-reveal-delay="2">
        Compact 4-column index — hover for a row glow.
        Monospace keys, hairline rules, no card chrome. Minimal but alive.
      </p>
    </header>

    <div class="stack-cols" data-reveal data-reveal-delay="3">
      {categories.map((cat, i) => (
        <div class="stack-col">
          <span class="stack-col-accent" aria-hidden="true"></span>
          <header class="stack-col-head">
            <span class="mono stack-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="stack-num-slash mono" aria-hidden="true">/</span>
            <h3 class="stack-col-title">{cat.title}</h3>
          </header>
          <ul class="stack-col-list" role="list">
            {cat.items.map((it, j) => (
              <li class="stack-row">
                <span class="mono stack-row-idx">{String(j + 1).padStart(2, '0')}</span>
                <span class="stack-row-name">{it.name}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ─── Layout ──────────────────────────────────────────────── */
  .stack {
    padding-block: var(--space-13) var(--space-13);
    position: relative;
  }

  .stack-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-5);
  }

  /* ─── Header ──────────────────────────────────────────────── */
  .stack-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-8);
    align-items: end;
    margin-bottom: var(--space-3);
  }

  .stack-heading {
    grid-column: 1 / 2;
    font-size: var(--text-display-l);
    color: var(--text);
    line-height: 1.02;
  }

  .stack-accent {
    color: var(--primary-soft);
    font-style: italic;
    font-weight: 300;
  }

  .stack-lede {
    grid-column: 2 / 3;
    color: var(--text-muted);
    font-size: var(--text-body-l);
    line-height: 1.55;
    max-width: 46ch;
    justify-self: end;
    padding-bottom: 6px;
  }

  /* ─── Compact 4-column index ──────────────────────────────── */
  .stack-cols {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--rule);
    margin-top: var(--space-2);
  }

  .stack-col {
    position: relative;
    padding: var(--space-3) var(--space-3) var(--space-3) var(--space-3);
    border-right: 1px solid var(--rule);
    overflow: hidden;
    transition: background 360ms ease;
  }

  .stack-col:first-child { padding-left: 0; }
  .stack-col:last-child  { padding-right: 0; border-right: none; }

  /* Mouse-following radial hover glow (Linear/Vercel feel) */
  .stack-col::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      260px circle at var(--mx, 50%) var(--my, 0%),
      rgba(96, 165, 250, 0.10),
      rgba(96, 165, 250, 0.04) 40%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 360ms ease;
    pointer-events: none;
  }

  .stack-col:hover::before { opacity: 1; }

  /* 1px amber accent that draws across the top on hover */
  .stack-col-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      var(--amber) 50%,
      transparent 100%
    );
    transform: scaleX(0);
    transform-origin: left center;
    opacity: 0.85;
    transition: transform 480ms cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .stack-col:hover .stack-col-accent {
    transform: scaleX(1);
  }

  /* ─── Column header ───────────────────────────────────────── */
  .stack-col-head {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding-bottom: 14px;
    margin-bottom: 10px;
    border-bottom: 1px solid var(--rule);
  }

  .stack-num {
    color: var(--amber);
    font-size: 11px;
    letter-spacing: 0.18em;
  }

  .stack-num-slash {
    color: var(--text-muted);
    opacity: 0.45;
    font-size: 11px;
    margin-right: 2px;
  }

  .stack-col-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--text);
    line-height: 1.1;
  }

  /* ─── Item list ───────────────────────────────────────────── */
  .stack-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .stack-row {
    display: grid;
    grid-template-columns: 26px minmax(0, 1fr);
    gap: 10px;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px dashed transparent;
    transition: border-color 240ms ease, padding-left 240ms ease;
    position: relative;
  }

  .stack-row + .stack-row {
    border-top: 1px dashed rgba(138, 148, 168, 0.18);
  }

  .stack-col:hover .stack-row + .stack-row {
    border-top-color: rgba(96, 165, 250, 0.28);
  }

  .stack-row-idx {
    color: var(--text-muted);
    font-size: 10px;
    letter-spacing: 0.12em;
    opacity: 0.55;
    transition: color 200ms ease, opacity 200ms ease;
  }

  .stack-col:hover .stack-row-idx {
    opacity: 0.85;
    color: var(--primary-soft);
  }

  .stack-row-name {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.005em;
  }

  /* ─── Responsive ──────────────────────────────────────────── */
  @media (max-width: 900px) {
    .stack-cols {
      grid-template-columns: 1fr 1fr;
    }

    .stack-col:nth-child(2) {
      border-right: none;
      padding-right: 0;
    }
    .stack-col:nth-child(3) {
      padding-left: 0;
      border-top: 1px solid var(--rule);
      padding-top: var(--space-3);
    }
    .stack-col:nth-child(4) {
      border-top: 1px solid var(--rule);
      padding-top: var(--space-3);
    }
  }

  @media (max-width: 600px) {
    .stack {
      padding-block: var(--space-8);
    }

    .stack-header {
      grid-template-columns: 1fr;
      gap: var(--space-3);
      align-items: start;
    }

    .stack-heading { grid-column: 1 / -1; font-size: 40px; }
    .stack-lede    { grid-column: 1 / -1; justify-self: start; }

    .stack-cols {
      grid-template-columns: 1fr;
    }

    .stack-col {
      border-right: none;
      border-bottom: 1px solid var(--rule);
      border-top: none;
      padding: var(--space-3) 0;
    }

    .stack-col:last-child {
      border-bottom: none;
    }

    .stack-col:nth-child(3),
    .stack-col:nth-child(4) {
      padding-top: var(--space-3);
      border-top: none;
    }
  }
</style>

<script>
  // ─── Mouse-following hover gradient ────────────────────────
  // Updates --mx / --my CSS vars on the hovered column so the
  // ::before radial gradient tracks the cursor (Linear/Vercel feel).
  const cols = document.querySelectorAll<HTMLElement>('.stack-col');
  cols.forEach((col) => {
    col.addEventListener('pointermove', (e) => {
      const rect = col.getBoundingClientRect();
      const mx = ((e.clientX - rect.left) / rect.width) * 100;
      const my = ((e.clientY - rect.top) / rect.height) * 100;
      col.style.setProperty('--mx', `${mx}%`);
      col.style.setProperty('--my', `${my}%`);
    });
    col.addEventListener('pointerleave', () => {
      col.style.removeProperty('--mx');
      col.style.removeProperty('--my');
    });
  });
</script>
