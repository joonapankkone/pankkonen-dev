---
// Contact — Section 05
// Clean closing section: email, GitHub, LinkedIn.
---

<section class="contact" id="contact" aria-labelledby="contact-heading">
  <div class="container contact-wrap">

    <header>
      <p class="section-index mono" data-reveal>05 · Contact</p>
      <h2 class="contact-heading" id="contact-heading" data-reveal data-reveal-delay="1">
        The fastest path is<br /><em>email.</em>
      </h2>
    </header>

    <div class="contact-grid" data-reveal data-reveal-delay="2">

      <!-- Primary: giant email display -->
      <a href="mailto:joonapankkone@gmail.com" class="contact-email">
        <p class="ce-eyebrow mono">REACH OUT</p>
        <p class="ce-addr">joonapankkone<wbr />@gmail.com</p>
      </a>

      <!-- Sidebar: GitHub + LinkedIn -->
      <aside class="contact-side">
        <p class="cs-eyebrow mono">ELSEWHERE</p>
        <a
          href="https://github.com/joonapankkone"
          target="_blank"
          rel="noopener noreferrer"
          class="cs-row"
        >
          <span>GitHub</span>
          <span class="mono">joonapankkone ↗</span>
        </a>
        <a
          href="https://linkedin.com/in/joona-pankkonen-b67463351"
          target="_blank"
          rel="noopener noreferrer"
          class="cs-row"
        >
          <span>LinkedIn</span>
          <span class="mono">joona-pankkonen ↗</span>
        </a>
      </aside>

    </div>

    <footer class="contact-footer" data-reveal data-reveal-delay="3">
      <p class="footer-copy mono">
        Built with Astro · Deployed on Cloudflare Pages ·
        <span class="footer-amber">pankkonen.dev</span>
      </p>
    </footer>

  </div>
</section>

<style>
  /* ─── Layout ──────────────────────────────────────────────── */
  .contact {
    /* Generous section height — editorial feel, like a magazine back page */
    padding-block: 120px 140px;
  }

  .contact-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    /* Individual row spacing via margin-top on children */
    gap: 0;
  }

  /* ─── Header ──────────────────────────────────────────────── */
  .contact-heading {
    font-size: var(--text-display-l);
    color: var(--text);
    line-height: 1.1;
    margin-top: var(--space-3);
  }

  .contact-heading em {
    color: var(--primary-soft);
    font-style: italic;
    font-weight: 300;
  }

  /* ─── Asymmetric grid ─────────────────────────────────────── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 64px;
    align-items: start;
    /* Space above — lands the "Reach out" border at editorial distance from heading */
    margin-top: 72px;
  }

  /* ─── Primary: giant email display ───────────────────────── */
  .contact-email {
    display: block;
    padding: 32px 0;
    border-block: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
  }

  .contact-email:focus-visible {
    outline: 2px solid var(--primary-soft);
    outline-offset: 3px;
  }

  .ce-eyebrow {
    color: var(--amber);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .ce-addr {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.4vw, 48px);
    color: var(--text);
    letter-spacing: -0.025em;
    line-height: 1.1;
    word-break: break-all;
    transition: color 220ms ease;
    margin: 0;
  }

  .contact-email:hover .ce-addr {
    color: var(--primary-soft);
  }

  /* ─── Sidebar: GitHub + LinkedIn ─────────────────────────── */
  .contact-side {
    /* Centre the sidebar block vertically within the email column's height
       so "ELSEWHERE" + rows sit cleanly inside the ruled email area */
    align-self: center;
    padding-top: 0;
  }

  .cs-eyebrow {
    color: var(--text-muted);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .cs-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    border-top: 1px solid var(--rule);
    color: var(--text);
    text-decoration: none;
    transition: color 200ms ease;
    font-size: var(--text-body-m);
  }

  .cs-row:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .cs-row:hover {
    color: var(--primary-soft);
  }

  .cs-row .mono {
    font-size: var(--text-mono-s);
    color: var(--text-muted);
    transition: color 200ms ease;
  }

  .cs-row:hover .mono {
    color: var(--primary-soft);
  }

  /* ─── Footer ──────────────────────────────────────────────── */
  .contact-footer {
    border-top: 1px solid var(--rule);
    /* 32px below the border text — comfortable, not cramped */
    padding-top: 32px;
    /* Large whitespace above footer rule — lets the section breathe */
    margin-top: 180px;
  }

  .footer-copy {
    font-size: var(--text-mono-s);
    color: var(--text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .footer-amber {
    color: var(--amber);
  }

  /* ─── Scroll reveal ──────────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-reveal][data-reveal-delay="1"] { transition-delay: 80ms; }
  [data-reveal][data-reveal-delay="2"] { transition-delay: 160ms; }
  [data-reveal][data-reveal-delay="3"] { transition-delay: 240ms; }
  [data-reveal][data-reveal-delay="4"] { transition-delay: 320ms; }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .contact {
      padding-block: 64px 80px;
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
      margin-top: 40px;
    }

    .contact-side {
      padding-top: 0;
    }

    .contact-footer {
      margin-top: 64px;
    }

    .ce-addr {
      font-size: clamp(24px, 7vw, 36px);
    }
  }
</style>
