---
// Contact — Section 06
// Clean closing section: email, GitHub, LinkedIn.
---

<section class="contact" id="contact">
  <div class="container contact-wrap">

    <header class="contact-header">
      <p class="section-index mono" data-reveal>06 · Contact</p>
      <h2 class="contact-heading" data-reveal data-reveal-delay="1">
        Let's talk<br />
        <span class="contact-accent">data</span>.
      </h2>
      <p class="contact-lede" data-reveal data-reveal-delay="2">
        Open to junior data and AI roles, collaborations, or just a good
        conversation about ML pipelines and sim racing.
      </p>
    </header>

    <div class="contact-links" data-reveal data-reveal-delay="3">

      <a href="mailto:joonapankkone@gmail.com" class="contact-item">
        <span class="ci-icon mono" aria-hidden="true">✉</span>
        <span class="ci-body">
          <span class="ci-label mono">Email</span>
          <span class="ci-value">joonapankkone@gmail.com</span>
        </span>
        <span class="ci-arrow" aria-hidden="true">↗</span>
      </a>

      <a
        href="https://github.com/joonapankkone"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-item"
      >
        <span class="ci-icon mono" aria-hidden="true">⌥</span>
        <span class="ci-body">
          <span class="ci-label mono">GitHub</span>
          <span class="ci-value">github.com/joonapankkone</span>
        </span>
        <span class="ci-arrow" aria-hidden="true">↗</span>
      </a>

      <a
        href="https://linkedin.com/in/joona-pankkonen-b67463351"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-item"
      >
        <span class="ci-icon mono" aria-hidden="true">◈</span>
        <span class="ci-body">
          <span class="ci-label mono">LinkedIn</span>
          <span class="ci-value">linkedin.com/in/joona-pankkonen-b67463351</span>
        </span>
        <span class="ci-arrow" aria-hidden="true">↗</span>
      </a>

    </div>

    <footer class="contact-footer" data-reveal data-reveal-delay="4">
      <p class="footer-copy mono">
        Built with Astro · Deployed on Cloudflare Pages ·
        <span class="footer-amber">pankkonen.dev</span>
      </p>
    </footer>

  </div>
</section>

<style>
  /* ─── Layout ──────────────────────────────────────────────── */
  .contact {
    padding-block: var(--space-13) var(--space-13);
  }

  .contact-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-10);
  }

  /* ─── Header ──────────────────────────────────────────────── */
  .contact-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-8);
    align-items: end;
  }

  .contact-header .section-index {
    grid-column: 1 / -1;
    margin-bottom: var(--space-3);
  }

  .contact-heading {
    grid-column: 1 / 2;
    font-size: var(--text-display-l);
    color: var(--text);
    line-height: 1.02;
  }

  .contact-accent {
    color: var(--primary-soft);
    font-style: italic;
    font-weight: 300;
  }

  .contact-lede {
    grid-column: 2 / 3;
    color: var(--text-muted);
    font-size: var(--text-body-l);
    line-height: 1.6;
    max-width: 44ch;
    justify-self: end;
    padding-bottom: 6px;
  }

  /* ─── Link cards ──────────────────────────────────────────── */
  .contact-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition:
      background 200ms ease,
      border-color 200ms ease,
      transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  .contact-item:hover {
    background: var(--surface-raised);
    border-color: var(--primary-soft);
    transform: translateY(-2px);
  }

  .contact-item:focus-visible {
    outline: 2px solid var(--primary-soft);
    outline-offset: 3px;
  }

  .ci-icon {
    font-size: 20px;
    color: var(--amber);
    flex-shrink: 0;
    line-height: 1;
  }

  .ci-body {
    display: flex;
    flex-direction: column;
    gap: 3px;
    flex: 1;
    min-width: 0;
  }

  .ci-label {
    font-size: var(--text-mono-s);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ci-value {
    font-size: var(--text-body-m);
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ci-arrow {
    color: var(--text-muted);
    font-size: 18px;
    flex-shrink: 0;
    transition: color 200ms ease, transform 200ms ease;
  }

  .contact-item:hover .ci-arrow {
    color: var(--primary-soft);
    transform: translate(2px, -2px);
  }

  /* ─── Footer ──────────────────────────────────────────────── */
  .contact-footer {
    border-top: 1px solid var(--rule);
    padding-top: var(--space-6);
  }

  .footer-copy {
    font-size: var(--text-mono-s);
    color: var(--text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .footer-amber {
    color: var(--amber);
  }

  /* ─── Scroll reveal ──────────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-reveal][data-reveal-delay="1"] { transition-delay: 80ms; }
  [data-reveal][data-reveal-delay="2"] { transition-delay: 160ms; }
  [data-reveal][data-reveal-delay="3"] { transition-delay: 240ms; }
  [data-reveal][data-reveal-delay="4"] { transition-delay: 320ms; }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .contact {
      padding-block: var(--space-8) var(--space-8);
    }

    .contact-header {
      grid-template-columns: 1fr;
    }

    .contact-heading {
      grid-column: 1 / -1;
    }

    .contact-lede {
      grid-column: 1 / -1;
      justify-self: start;
      max-width: 100%;
    }

    .contact-links {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .ci-value {
      font-size: var(--text-body-s);
    }
  }
</style>
