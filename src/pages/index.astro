---
import Layout from '../layouts/Layout.astro';
import Experience from '../components/Experience.astro';
import Stack from '../components/Stack.astro';
import Projects from '../components/Projects.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import ChapterMarker from '../components/ChapterMarker.astro';
import StackDivider from '../components/StackDivider.astro';
import ProjectsDivider from '../components/ProjectsDivider.astro';
---

<Layout>
  <ChapterMarker />

  <section class="hero container" id="hero">

    <!-- Left column -->
    <div class="hero-left">

      <div class="hero-eyebrow-row" id="hero-eyebrow-row">
        <p class="hero-eyebrow mono">pankkonen.dev</p>
        <span class="eyebrow-divider" aria-hidden="true"></span>
        <div class="hero-status">
          <span class="status-dot"></span>
          <span class="mono status-text">Open to opportunities</span>
        </div>
      </div>

      <h1 class="hero-name" id="hero-name">
        Joona<br />Pankkonen
      </h1>

      <p class="hero-tagline" id="hero-tagline">
        Data. Code. Systems.<br />
        <span class="hero-italic">And a 2× world title on the side.</span>
      </p>

      <a href="#contact" class="btn btn-ghost" id="hero-cta">Contact ↓</a>

    </div>

    <!-- Right column: photo -->
    <div class="hero-right" id="hero-image">
      <div class="hero-photo-wrap">
        <img
          src="/joona.jpeg"
          alt="Joona Pankkonen"
          class="hero-photo"
          width="440"
          height="587"
          loading="eager"
        />
        <!-- Bottom fade: blends photo into page background -->
        <div class="photo-fade-bottom"></div>
        <!-- Subtle blue glow accent -->
        <div class="photo-glow"></div>
      </div>
    </div>

  </section>

  <!-- Divider: hero → experience -->
  <div class="container section-divider" data-rule-reveal aria-hidden="true"></div>

  <!-- 01 · EXPERIENCE -->
  <Experience />

  <!-- Divider: experience → stack (side-rail wayfinder — also replaces the inline 02·Stack eyebrow) -->
  <StackDivider num="02" label="Stack" />

  <!-- 02 · STACK -->
  <Stack />

  <!-- Divider: stack → projects (centered § with twin hairlines glowing outward) -->
  <ProjectsDivider />

  <!-- 03 · PROJECTS -->
  <Projects />

  <!-- 04 · BEYOND THE CODE -->
  <About />

  <!-- Divider: beyond the code → contact -->
  <div class="container section-divider" data-rule-reveal aria-hidden="true"></div>

  <!-- 05 · CONTACT -->
  <Contact />

</Layout>

<style>
  /* ─── Hero layout ───────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: var(--space-8);
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  /* ─── Left column ───────────────────────────────────────────── */
  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ─── Eyebrow row (eyebrow + divider + status) ─────────────── */
  .hero-eyebrow-row {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 56px;
    opacity: 0;
  }

  .hero-eyebrow {
    color: var(--text-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: var(--text-mono-s);
    margin: 0;
  }

  .eyebrow-divider {
    width: 1px;
    height: 12px;
    background: var(--rule);
    flex-shrink: 0;
  }

  .hero-name {
    font-size: var(--text-display-xl);
    color: var(--text);
    margin-bottom: var(--space-3);
    opacity: 0;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(22px, 2vw, 28px);
    line-height: 1.35;
    max-width: 20ch;
    margin-bottom: 48px;
    color: var(--text);
    opacity: 0;
  }

  .hero-italic {
    color: var(--primary-soft);
    font-style: italic;
    font-weight: 300;
  }

  /* ─── Status dot ────────────────────────────────────────────── */
  .hero-status {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--amber);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
  }

  .status-text {
    color: var(--text-muted);
    font-size: var(--text-mono-s);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ─── Single CTA ───────────────────────────────────────────── */
  /* `.btn` / `.btn-ghost` rules live in global.css; just init     */
  /* opacity for the GSAP entrance.                                */
  #hero-cta {
    opacity: 0;
    align-self: flex-start; /* prevent flex-column stretch to full width */
  }

  /* ─── Right column: photo ───────────────────────────────────── */
  .hero-right {
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
  }

  .hero-photo-wrap {
    position: relative;
    width: 100%;
    max-width: 440px;
    border-radius: 16px;
    overflow: hidden;
    /* Thin blue accent border */
    box-shadow:
      0 0 0 1px var(--rule),
      0 0 40px 0 rgba(59, 130, 246, 0.08);
  }

  .hero-photo {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: center top;
    /* Soften any blur/noise slightly */
    filter: contrast(1.04) brightness(0.97);
  }

  /* Gradient fade at the bottom — blends into page bg */
  .photo-fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 45%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(11, 18, 32, 0.55) 60%,
      rgba(11, 18, 32, 0.92) 100%
    );
    pointer-events: none;
  }

  /* Subtle blue glow — sits behind the image at the sides */
  .photo-glow {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    box-shadow: inset 0 0 0 1px rgba(59, 130, 246, 0.12);
    pointer-events: none;
  }

  /* ─── Mobile ────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 100px;
      gap: var(--space-8);
    }

    .hero-right {
      order: -1;
    }

    .hero-photo-wrap {
      max-width: 100%;
    }

    .hero-photo {
      aspect-ratio: 4 / 3;
      /* Drop the framing window so the face sits closer to centre on  */
      /* the wider mobile crop (4/3) instead of clinging to the top.    */
      object-position: center 30%;
    }
  }

  /* ─── Section divider ──────────────────────────────────────── */
  .section-divider {
    padding-block: var(--space-3);
  }
</style>

<script>
  import { gsap } from 'gsap';

  // ─── Hero load stagger ─────────────────────────────────────
  gsap.set(['#hero-eyebrow-row', '#hero-name', '#hero-tagline', '#hero-cta', '#hero-image'], {
    y: 24,
  });

  const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });

  tl
    .to('#hero-eyebrow-row', { opacity: 1, y: 0, duration: 0.6 }, 0.1)
    .to('#hero-name',        { opacity: 1, y: 0, duration: 0.7 }, 0.25)
    .to('#hero-tagline',     { opacity: 1, y: 0, duration: 0.6 }, 0.45)
    .to('#hero-cta',         { opacity: 1, y: 0, duration: 0.5 }, 0.6)
    .to('#hero-image',       { opacity: 1, y: 0, duration: 0.7 }, 0.35);

  // ─── Scroll reveal ─────────────────────────────────────────
  // Spring easing + 28px lift — all [data-reveal] elements.
  // Section headers use individual child reveals for stagger.
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReduced) {
    document.querySelectorAll('[data-reveal]').forEach((el) => {
      el.classList.add('is-visible');
    });
  } else {
    // Flicker-resistant reveal controller.
    //
    // Two layers of protection against the edge-of-viewport flutter that
    // used to affect Stack cards at the top of the screen:
    //
    //   1. Debounced removal — if an exit event fires but the element
    //      re-enters within 400ms, the pending removal is cancelled.
    //   2. Bounding-rect gate — even after the 400ms, we only drop
    //      `is-visible` if the element is ACTUALLY out of the viewport
    //      (rect.bottom < 0 || rect.top > innerHeight). A card that is
    //      still partially visible keeps its revealed state, which kills
    //      the "bottom-of-card flicker" when sitting near the top edge.
    //
    // Replay still works in both directions: once the element is fully
    // off-screen, is-visible is removed, so the next re-entry re-triggers
    // the animation.
    const removeTimers = new WeakMap<Element, ReturnType<typeof setTimeout>>();
    const REMOVE_DELAY = 400;

    const isFullyOffscreen = (el: Element) => {
      const rect = el.getBoundingClientRect();
      const vh = window.innerHeight || document.documentElement.clientHeight;
      return rect.bottom <= 0 || rect.top >= vh;
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const el = entry.target;

          if (entry.isIntersecting) {
            // Cancel any pending removal — element came back into view.
            const pending = removeTimers.get(el);
            if (pending !== undefined) {
              clearTimeout(pending);
              removeTimers.delete(el);
            }
            // Double rAF: ensures opacity:0 is painted before the
            // transition kicks in, so nothing skips.
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                el.classList.add('is-visible');
              });
            });
          } else {
            // Replace any previous pending timer for this element.
            const prev = removeTimers.get(el);
            if (prev !== undefined) clearTimeout(prev);

            const timer = setTimeout(() => {
              // Gate: only strip is-visible if the element is truly
              // out of viewport. Prevents flicker when the IO threshold
              // sits on a card edge.
              if (isFullyOffscreen(el)) {
                el.classList.remove('is-visible');
              }
              removeTimers.delete(el);
            }, REMOVE_DELAY);
            removeTimers.set(el, timer);
          }
        });
      },
      {
        rootMargin: '-8% 0px -6% 0px',
        threshold: 0.06,
      }
    );

    document.querySelectorAll('[data-reveal], [data-rule-reveal]').forEach((el) => io.observe(el));
  }
</script>
