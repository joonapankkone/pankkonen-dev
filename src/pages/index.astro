---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="container" style="padding-top: 80px;">
    <p class="mono" style="color: var(--text-muted); letter-spacing: 0.15em; text-transform: uppercase; font-size: var(--text-mono-s); margin-bottom: 24px;">
      pankkonen.dev — design system ✓
    </p>

    <h1 style="font-size: var(--text-display-xl); color: var(--text); margin-bottom: 16px;">
      Joona<br />Pankkonen
    </h1>

    <p style="font-size: var(--text-body-l); color: var(--text-muted); margin-bottom: 48px;">
      IT Engineering · Data Analytics · AI
    </p>

    <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 64px;">
      <div style="width: 48px; height: 48px; background: var(--bg); border: 1px solid var(--rule); border-radius: 4px;"></div>
      <div style="width: 48px; height: 48px; background: var(--surface); border: 1px solid var(--rule); border-radius: 4px;"></div>
      <div style="width: 48px; height: 48px; background: var(--deep-blue); border-radius: 4px;"></div>
      <div style="width: 48px; height: 48px; background: var(--primary); border-radius: 4px;"></div>
      <div style="width: 48px; height: 48px; background: var(--primary-soft); border-radius: 4px;"></div>
      <div style="width: 48px; height: 48px; background: var(--amber); border-radius: 4px;"></div>
    </div>

    <div class="rule"></div>
    <p class="mono" style="color: var(--text-muted); margin-top: 24px; font-size: var(--text-mono-s);">
      Vaihe 1 valmis — Astro + Tailwind + GSAP ✓
    </p>
  </div>
</Layout>
